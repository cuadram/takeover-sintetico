# ─────────────────────────────────────────────────────────────────────────────
# FacturaFlow — Variables de entorno requeridas
# SOFIA Sprint 1 RT-001 + RT-002
#
# INSTRUCCIONES:
#   1. Copiar este fichero como .env en el entorno de desarrollo local
#   2. Completar los valores — NUNCA commitear .env con valores reales
#   3. En producción: configurar como secrets del sistema operativo / Kubernetes
#   4. .env está en .gitignore — .env.example sí se versiona
#
# GENERACIÓN de JWTAUTH__SECRET (≥ 256 bits):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   -- o --
#   openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────

# JWT signing secret — mínimo 256 bits, base64
# Mapeado a: JwtSettings:Secret (JWTAUTH__SECRET → JwtSettings:Secret vía ASP.NET Core)
JWTAUTH__SECRET=

# Connection string completa SQL Server
# Mapeado a: ConnectionStrings:DefaultConnection
CONNECTIONSTRINGS__DEFAULTCONNECTION=Server=localhost;Database=FacturaFlowDB;User=sa;Password=TU_PASSWORD_AQUI;TrustServerCertificate=True

# ─── Solo para CI (configurar como GitHub Secrets) ───────────────────────────
# JWTAUTH_SECRET_TEST=<secret para entorno de test>
# DB_CONNECTIONSTRING_TEST=<connection string BD de test>
