# ─────────────────────────────────────────────────────────────────────────────
# .dockerignore — FacturaFlow
# Excluye ficheros innecesarios del contexto de build Docker
# ─────────────────────────────────────────────────────────────────────────────
**/.git
**/.env
**/.env.*
!**/.env.example
**/bin
**/obj
**/*.user
**/TestResults
**/coverage
**/.vs
**/.vscode
**/node_modules
**/scripts
**/.github
**/docs
